NODE_ENV=local
PORT=3000
CORS_ORIGINS=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your-local-username
DB_PASSWORD=
DB_NAME=client_data
# DB_SSL=true          # required for Neon/most managed Postgres in production

# identity-service must be running locally for token verification to work --
# see identity-service's "JWKS & Token Issuance" wiki page.
AUTH_JWKS_URI=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER=http://localhost:8080
