meta {
  name: Personas - Create
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/customers/:customerId/personas
  body: json
  auth: bearer
}

params:path {
  customerId: paste-a-customer-id-here
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "name": "Jane Doe",
    "email": "jane@acme.example.com",
    "title": "VP Engineering"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
}
