meta {
  name: Health - Readiness
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/health/ready
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.status: eq ok
}

docs {
  Public, checks the Postgres connection is actually up. Kubernetes-style readiness
  probe -- a failure here should pull the instance out of the load balancer.
}
